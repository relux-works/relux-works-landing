---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const features = [
  {
    key: 'state',
    icon: 'box',
  },
  {
    key: 'middleware',
    icon: 'arrow',
  },
  {
    key: 'tools',
    icon: 'wrench',
  },
] as const;
---

<section id="ecosystem" class="section">
  <div class="container">
    <h2 class="section-title">{t(lang, 'ecosystem.title')}</h2>
    <p class="section-subtitle">{t(lang, 'ecosystem.subtitle')}</p>
    <p class="ecosystem-description">{t(lang, 'ecosystem.description')}</p>

    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon">
            {feature.icon === 'box' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
              </svg>
            )}
            {feature.icon === 'arrow' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="2" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
                <circle cx="7" cy="12" r="2" />
              </svg>
            )}
            {feature.icon === 'wrench' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
              </svg>
            )}
          </div>
          <div class="feature-content">
            <h3 class="feature-title">{t(lang, `ecosystem.features.${feature.key}.title`)}</h3>
            <p class="feature-description">{t(lang, `ecosystem.features.${feature.key}.description`)}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="ecosystem-cta">
      <a href="https://github.com/ivalx1s" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
        </svg>
        {t(lang, 'ecosystem.cta')}
      </a>
    </div>
  </div>
</section>

<style>
  .ecosystem-description {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: 720px;
    margin-bottom: var(--space-xl);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-link);
    border-radius: var(--radius-sm);
    padding: var(--space-lg);
    transition:
      border-color var(--transition-base),
      background var(--transition-base);
  }

  .feature-card:hover {
    border-left-color: var(--color-accent);
    background: var(--color-surface);
  }

  .feature-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-link);
    transition: color var(--transition-base);
  }

  .feature-card:hover .feature-icon {
    color: var(--color-accent);
  }

  .feature-content {
    flex: 1;
    min-width: 0;
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .feature-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .ecosystem-cta {
    display: flex;
    justify-content: flex-start;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
