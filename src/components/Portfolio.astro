---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const projects = [
  {
    key: 'tnl',
    link: 'https://apps.apple.com/us/app/t-l-learn-foreign-words/id548917415',
    platform: 'appstore' as const,
    icon: null,
  },
  {
    key: 'tundra',
    link: 'https://testflight.apple.com/join/TGyPY5G2',
    platform: 'testflight' as const,
    icon: null,
  },
  {
    key: 'waio',
    link: 'https://testflight.apple.com/join/JDN4XVb7',
    platform: 'testflight' as const,
    icon: '/waio-recorder-icon.svg',
  },
] as const;
---

<section id="portfolio" class="section">
  <div class="container">
    <h2 class="section-title">{t(lang, 'portfolio.title')}</h2>
    <p class="section-subtitle">{t(lang, 'portfolio.subtitle')}</p>

    <div class="portfolio-grid">
      {projects.map((project) => (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class={`portfolio-card portfolio-card--${project.key}`}
        >
          <div class="card-content">
            {project.icon && (
              <div class="card-icon-wrap">
                <img src={project.icon} alt={`${t(lang, `portfolio.${project.key}.title`)} icon`} class="card-icon" loading="lazy" />
              </div>
            )}
            <h3 class="card-title">{t(lang, `portfolio.${project.key}.title`)}</h3>
            <p class="card-description">{t(lang, `portfolio.${project.key}.description`)}</p>
          </div>
          <div class="card-footer">
            <span class={`platform-badge platform-badge--${project.platform}`}>
              {project.platform === 'appstore' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.56 2.93 11.3 4.7 7.72C5.57 5.94 7.36 4.86 9.28 4.84C10.56 4.82 11.78 5.72 12.58 5.72C13.38 5.72 14.86 4.62 16.42 4.78C17.09 4.81 18.89 5.06 20.04 6.72C19.93 6.79 17.64 8.12 17.67 10.88C17.7 14.18 20.55 15.27 20.59 15.29C20.56 15.37 20.12 16.9 19.03 18.47L18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/>
                </svg>
              )}
              {project.platform === 'testflight' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L2 7l10 5 10-5-10-5z" />
                  <path d="M2 17l10 5 10-5" />
                  <path d="M2 12l10 5 10-5" />
                </svg>
              )}
              {t(lang, `portfolio.${project.key}.badge`)}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .portfolio-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .portfolio-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.6;
    z-index: 0;
    transition: opacity var(--transition-base);
  }

  .portfolio-card:hover::before {
    opacity: 1;
  }

  .portfolio-card--tnl {
    background: var(--color-surface);
  }

  .portfolio-card--tnl::before {
    background: linear-gradient(
      135deg,
      var(--color-surface) 0%,
      var(--color-primary-light) 50%,
      var(--color-surface) 100%
    );
  }

  .portfolio-card--tundra {
    background: var(--color-surface);
  }

  .portfolio-card--tundra::before {
    background: linear-gradient(
      135deg,
      var(--color-surface) 0%,
      var(--color-bg-alt) 40%,
      var(--color-primary-light) 100%
    );
  }

  .portfolio-card--waio {
    background: var(--color-surface);
  }

  .portfolio-card--waio::before {
    background: linear-gradient(
      135deg,
      #5f64d6 0%,
      #8e90dd 55%,
      #b6b3e7 100%
    );
    opacity: 0.16;
  }

  .portfolio-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 24px rgba(233, 69, 96, 0.1);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .card-content {
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-lg);
  }

  .card-icon-wrap {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: var(--space-md);
    border: 1px solid rgba(255, 255, 255, 0.45);
    box-shadow: 0 8px 20px rgba(37, 40, 103, 0.22);
  }

  .card-icon {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .card-footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .platform-badge--appstore {
    background: var(--color-bg-alt);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .platform-badge--testflight {
    background: var(--color-bg-alt);
    color: var(--color-link);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
