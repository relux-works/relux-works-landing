---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>

  <div class="container hero-content">
    <h1 class="hero-title">{t(lang, 'hero.title')}</h1>
    <p class="hero-subtitle">{t(lang, 'hero.subtitle')}</p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-primary hero-btn">
        {t(lang, 'hero.cta_primary')}
      </a>
      <a href="#ecosystem" class="btn btn-outline hero-btn">
        {t(lang, 'hero.cta_secondary')}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    overflow: hidden;
  }

  /* Background decorations */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Dot grid pattern */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      var(--color-border) 1px,
      transparent 1px
    );
    background-size: 40px 40px;
    opacity: 0.35;
    mask-image: radial-gradient(
      ellipse 70% 60% at 50% 40%,
      black 20%,
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 70% 60% at 50% 40%,
      black 20%,
      transparent 70%
    );
  }

  /* Radial glow */
  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(
      ellipse at center,
      rgba(233, 69, 96, 0.08) 0%,
      rgba(124, 140, 248, 0.04) 40%,
      transparent 70%
    );
    filter: blur(40px);
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    max-width: 14ch;
    margin-bottom: var(--space-lg);
    background: linear-gradient(
      135deg,
      var(--color-text) 0%,
      var(--color-text-secondary) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }

  .hero-btn {
    padding: var(--space-sm) var(--space-xl);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: calc(100dvh - var(--header-height));
    }

    .hero-content {
      padding-top: var(--space-xl);
      padding-bottom: var(--space-xl);
    }

    .hero-glow {
      width: 400px;
      height: 300px;
    }

    .hero-grid {
      background-size: 30px 30px;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }

    .hero-btn {
      justify-content: center;
      text-align: center;
    }
  }
</style>
