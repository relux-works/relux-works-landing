---
import '../styles/global.css';
import { type Lang, languages, langLabels, getAlternateLinks, t } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const pageTitle = title || `Relux Works — ${t(lang, 'hero.title')}`;
const pageDescription = description || t(lang, 'hero.subtitle');
const alternates = getAlternateLinks(Astro.url.pathname);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Inter + Noto Sans Armenian + Noto Sans Georgian -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+Armenian:wght@400;500;600;700&family=Noto+Sans+Georgian:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- hreflang -->
    {alternates.map(({ lang: l, href }) => (
      <link rel="alternate" hreflang={l} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="/en/" />

    <slot name="head" />
  </head>
  <body>
    <slot />
    <script is:inline>
      const ONE_YEAR_SECONDS = 60 * 60 * 24 * 365;

      document.addEventListener(
        'click',
        (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest('a[data-lang-choice]');
          if (!(link instanceof HTMLAnchorElement)) return;

          const locale = link.dataset.langChoice;
          if (!locale) return;

          const secure = window.location.protocol === 'https:' ? '; Secure' : '';
          document.cookie = `nf_lang=${encodeURIComponent(locale)}; Path=/; Max-Age=${ONE_YEAR_SECONDS}; SameSite=Lax${secure}`;
        },
        true
      );
    </script>
  </body>
</html>
