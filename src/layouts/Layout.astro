---
import '../styles/global.css';
import { type Lang, languages, langLabels, getAlternateLinks, t } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const pageTitle = title || t(lang, 'meta.title');
const pageDescription = description || t(lang, 'meta.description');
const site = Astro.site ?? new URL('https://relux.works');
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const alternates = getAlternateLinks(Astro.url.pathname).map(({ lang: l, href }) => ({
  lang: l,
  href: new URL(href, site).href,
}));

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site.origin}/#organization`,
  name: 'Relux Works',
  legalName: 'RELUX WORKS LLC',
  alternateName: ['Relux Works Studio', 'Relux Works LLC'],
  description:
    'AI-native software development studio and agentic development studio building fixed-price MVPs, mobile, web, and AI products for startup founders, with full-service app publishing, scaling, and vibe-code rescue.',
  url: `${site.origin}/`,
  logo: `${site.origin}/logo.svg`,
  email: 'ivan@relux.works',
  foundingDate: '2026',
  taxID: '03036828',
  numberOfEmployees: {
    '@type': 'QuantitativeValue',
    minValue: 2,
    maxValue: 10,
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Orbeli Brothers St. 19',
    addressLocality: 'Tsaghkadzor',
    addressRegion: 'Kotayq',
    postalCode: '2310',
    addressCountry: 'AM',
  },
  areaServed: 'Worldwide',
  sameAs: ['https://github.com/relux-works', 'https://www.linkedin.com/company/relux-works'],
  knowsAbout: [
    'AI MVP development',
    'AI-assisted software development',
    'MVP development for startups',
    'AI agent engineering',
    'iOS and Swift development',
    'Android and Kotlin development',
    'React Native cross-platform development',
    'Web application development',
    'Go and Rust backend development',
    'Embedded software for microcontrollers',
    'Enterprise software architecture',
    'App Store and Google Play publishing',
    'Vibe-code rescue and refactoring of AI-generated code',
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Relux Works" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Inter + Noto Sans Armenian + Noto Sans Georgian -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+Armenian:wght@400;500;600;700&family=Noto+Sans+Georgian:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- hreflang -->
    {alternates.map(({ lang: l, href }) => (
      <link rel="alternate" hreflang={l} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates.find((a) => a.lang === 'en')?.href} />

    <!-- Structured data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <slot name="head" />
  </head>
  <body>
    <slot />
    <script is:inline>
      const ONE_YEAR_SECONDS = 60 * 60 * 24 * 365;

      document.addEventListener(
        'click',
        (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest('a[data-lang-choice]');
          if (!(link instanceof HTMLAnchorElement)) return;

          const locale = link.dataset.langChoice;
          if (!locale) return;

          const secure = window.location.protocol === 'https:' ? '; Secure' : '';
          document.cookie = `nf_lang=${encodeURIComponent(locale)}; Path=/; Max-Age=${ONE_YEAR_SECONDS}; SameSite=Lax${secure}`;
        },
        true
      );
    </script>
  </body>
</html>
