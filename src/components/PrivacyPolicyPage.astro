---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import type { Lang } from '../i18n/utils';
import PrivacyPolicyContent from '../content/privacy-policy.md';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Layout
  lang={lang}
  title="Privacy Policy | Relux Works"
  description="Privacy Policy for Relux Works LLC."
>
  <main class="legal-page">
    <div class="container">
      <article class="legal-card">
        <PrivacyPolicyContent />
      </article>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .legal-page {
    padding: var(--space-xl) 0;
  }

  .legal-card {
    max-width: 860px;
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 3rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
      var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
  }

  .legal-card :global(h1) {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .legal-card :global(h2) {
    font-size: 1.25rem;
    line-height: 1.3;
    margin: var(--space-lg) 0 var(--space-sm);
    color: var(--color-text);
  }

  .legal-card :global(p) {
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }

  .legal-card :global(strong) {
    color: var(--color-text);
  }

  .legal-card :global(a) {
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .legal-page {
      padding: var(--space-lg) 0;
    }
  }
</style>
