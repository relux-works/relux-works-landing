---
import LegalPage from './LegalPage.astro';
import type { Lang } from '../i18n/utils';
import TermsOfUseContent from '../content/terms-of-use.md';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<LegalPage
  lang={lang}
  title="Terms of Use | Relux Works"
  description="Terms of Use for Relux Works LLC."
  Content={TermsOfUseContent}
/>
