---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const channels = [
  {
    key: 'github',
    href: 'https://github.com/ivalx1s',
    icon: 'github',
  },
  {
    key: 'discussions',
    href: '#',
    icon: 'discussions',
  },
] as const;
---

<section id="community" class="section">
  <div class="container">
    <h2 class="section-title">{t(lang, 'community.title')}</h2>
    <p class="section-subtitle">{t(lang, 'community.subtitle')}</p>

    <p class="community-description">{t(lang, 'community.description')}</p>

    <div class="channels-grid">
      {channels.map((channel) => (
        <a href={channel.href} class="channel-card" target="_blank" rel="noopener noreferrer">
          <div class="channel-icon">
            {channel.icon === 'github' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {channel.icon === 'discussions' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                <line x1="9" y1="9" x2="15" y2="9" />
                <line x1="9" y1="13" x2="13" y2="13" />
              </svg>
            )}
          </div>
          <span class="channel-label">{t(lang, `community.${channel.key}`)}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .community-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: 680px;
    margin-bottom: var(--space-xl);
  }

  .channels-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .channel-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .channel-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 20px rgba(233, 69, 96, 0.08);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .channel-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    background: var(--color-bg-alt);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .channel-label {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  @media (min-width: 640px) {
    .channels-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .channel-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: var(--space-xl) var(--space-lg);
    }

    .channel-icon {
      width: 3.5rem;
      height: 3.5rem;
      margin-bottom: var(--space-sm);
    }
  }
</style>
